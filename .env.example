# Environment config for 01-mm-pro
# Copy to .env and fill PRIVATE_KEY. All other values have sane defaults.

# REQUIRED — Solana wallet private key (base58) that has a funded 01.xyz account
PRIVATE_KEY=

# --- Markets (multi-symbol) ---
# Comma-separated list of markets to run in ONE process (shared wallet session).
# Default if unset: BTC,ETH,SOL. CLI args override this (e.g. `npm run bot -- BTC`).
SYMBOLS=BTC,ETH,SOL

# --- Core quoting ---
SPREAD_BPS=8              # base half-spread from fair price
TAKE_PROFIT_BPS=3        # half-spread in close mode (must cover fees)

# Sizing: margin committed per entry. Order notional is auto-derived per market
# from its initial-margin fraction (imf): notional = MARGIN_PER_ENTRY_USD / imf.
# 01.xyz is cross-margin; leverage is fixed per market (max = 1/imf) and the bot
# does NOT change it. Set MARGIN_PER_ENTRY_USD=0 to fall back to ORDER_SIZE_USD.
MARGIN_PER_ENTRY_USD=2   # target margin per entry (USD)
ORDER_SIZE_USD=200       # fallback per-side notional if margin sizing disabled

WARMUP_SECONDS=10        # min samples before quoting

# --- Inventory management ---
MAX_INVENTORY_USD=1000   # HARD cap on |position|; bot stops growing past this
CLOSE_THRESHOLD_USD=600  # enter close-bias when |position| >= this
INVENTORY_SKEW_BPS=6     # max fair-price skew at full inventory (mean-reverts faster)

# --- Per-symbol inventory caps (optional) ---
# Override the global cap per coin. Format: MAX_INVENTORY_USD_<SYM>.
# Give stable/liquid coins more room, volatile coins less. The close-bias
# trigger auto-scales to the same proportion as the global pair (here 0.6),
# so you only need ONE number per coin. Override the close trigger too with
# CLOSE_THRESHOLD_USD_<SYM> if you want a different ratio for a specific coin.
# MAX_INVENTORY_USD_BTC=1500   # stable, liquid -> bigger budget   (close auto ~900)
# MAX_INVENTORY_USD_ETH=1000   #                                   (close auto ~600)
# MAX_INVENTORY_USD_SOL=500    # volatile -> smaller budget        (close auto ~300)
# CLOSE_THRESHOLD_USD_SOL=250  # optional: tighter close trigger for SOL specifically

# --- Dynamic spread (volatility-aware) ---
DYNAMIC_SPREAD=true
VOL_WINDOW_SEC=60
VOL_SPREAD_MULT=1.0
MAX_SPREAD_BPS=40        # spread ceiling

# --- Risk guards ---
MAX_DRAWDOWN_USD=50      # KILL SWITCH: halt + cancel if session realized PnL <= -this
STALE_FEED_MS=5000       # halt quoting if a price feed is older than this
MAX_CONSECUTIVE_ERRORS=5 # halt after N consecutive update errors

# --- Funding-aware bias ---
FUNDING_AWARE=true
FUNDING_POLL_MS=60000
FUNDING_SKEW_BPS=4

# --- Anti-trend guard ---
# Market making bleeds during strong trends (you keep buying a falling knife /
# selling into a rocket). This widens or pauses the AGAINST-trend side based on
# signed directional drift (least-squares slope over VOL_WINDOW_SEC).
#   |drift| <  threshold        -> no effect (normal symmetric quoting)
#   threshold <= |drift| < pause -> widen the against-trend side proportionally
#   |drift| >= pause            -> STOP quoting the against-trend side entirely
ANTI_TREND_GUARD=true
TREND_DRIFT_THRESHOLD_BPS=8   # start defending above this directional drift
TREND_PAUSE_DRIFT_BPS=20      # fully pause against-trend side above this
TREND_SPREAD_MULT=1.5         # extra against-trend half-spread = (|drift|-thresh)*this
